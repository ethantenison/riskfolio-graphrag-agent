@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rf: <https://example.com/riskfolio/kg#> .

rf:Concept a owl:Class ;
    rdfs:label "Concept" .

rf:ConstraintType a owl:Class ;
    rdfs:label "ConstraintType" .

rf:DECLARES a owl:ObjectProperty ;
    rdfs:label "DECLARES" .

rf:DEMONSTRATES a owl:ObjectProperty ;
    rdfs:label "DEMONSTRATES" .

rf:DESCRIBES a owl:ObjectProperty ;
    rdfs:label "DESCRIBES" .

rf:DocPage a owl:Class ;
    rdfs:label "DocPage" .

rf:Estimator a owl:Class ;
    rdfs:label "Estimator" .

rf:ExampleNotebook a owl:Class ;
    rdfs:label "ExampleNotebook" .

rf:HAS_CHUNK a owl:ObjectProperty ;
    rdfs:label "HAS_CHUNK" .

rf:HAS_PARAMETER a owl:ObjectProperty ;
    rdfs:label "HAS_PARAMETER" .

rf:IMPLEMENTS a owl:ObjectProperty ;
    rdfs:label "IMPLEMENTS" .

rf:MENTIONS a owl:ObjectProperty ;
    rdfs:label "MENTIONS" .

rf:PRODUCES_REPORT a owl:ObjectProperty ;
    rdfs:label "PRODUCES_REPORT" .

rf:Parameter a owl:Class ;
    rdfs:label "Parameter" .

rf:PlotType a owl:Class ;
    rdfs:label "PlotType" .

rf:PortfolioMethod a owl:Class ;
    rdfs:label "PortfolioMethod" .

rf:PythonClass a owl:Class ;
    rdfs:label "PythonClass" .

rf:PythonFunction a owl:Class ;
    rdfs:label "PythonFunction" .

rf:RELATED_TO a owl:ObjectProperty ;
    rdfs:label "RELATED_TO" .

rf:ReportType a owl:Class ;
    rdfs:label "ReportType" .

rf:RiskMeasure a owl:Class ;
    rdfs:label "RiskMeasure" .

rf:SUPPORTS_CONSTRAINT a owl:ObjectProperty ;
    rdfs:label "SUPPORTS_CONSTRAINT" .

rf:SUPPORTS_RISK_MEASURE a owl:ObjectProperty ;
    rdfs:label "SUPPORTS_RISK_MEASURE" .

rf:Solver a owl:Class ;
    rdfs:label "Solver" .

rf:TestCase a owl:Class ;
    rdfs:label "TestCase" .

rf:USES a owl:ObjectProperty ;
    rdfs:label "USES" .

rf:USES_ESTIMATOR a owl:ObjectProperty ;
    rdfs:label "USES_ESTIMATOR" .

rf:VALIDATES a owl:ObjectProperty ;
    rdfs:label "VALIDATES" .

